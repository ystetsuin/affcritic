# Database (Postgres з pgvector — Neon або Supabase)

DATABASE_URL=postgresql://user:password@host:5432/affcritic

# Telegram Scraper (потрібно лише для локальних запусків scraper/main.py і stats_collector.py)

TG_API_ID=your_api_id
TG_API_HASH=your_api_hash
TG_SESSION_NAME=affcritic

# OpenAI (потрібно для embeddings і GPT в lib/pipeline.ts)

OPENAI_API_KEY=sk-your-openai-api-key

# Admin Basic Auth (захист /admin/*, /api/admin/*, mutating /api/* endpoints)
# Якщо не задано — admin-зона повертає 503. На проді обов'язково.

ADMIN_USER=admin
ADMIN_PASS=change-me-to-a-strong-password

# App

NODE_ENV=development
